---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  lang?: 'zh' | 'en';
  alternate?: string;
}

const { title, description, lang = 'zh', alternate = lang === 'zh' ? 'en/' : '' } = Astro.props;
const base = import.meta.env.BASE_URL;
const home = lang === 'zh' ? base : `${base}en/`;
const zh = lang === 'zh';

const footerLinks = [
  { label: 'GitHub', href: 'https://github.com/dull-bird/DeepOrbit' },
  { label: zh ? '示例 Vault' : 'Example Vault', href: 'https://github.com/dull-bird/deeporbit-example-vault' },
  { label: 'teach-me', href: 'https://github.com/dull-bird/teach-me-skill' },
  { label: zh ? '文档' : 'Docs', href: `${home}docs/` },
];
---
<!doctype html>
<html lang={lang} data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <link rel="icon" href={`${base}favicon.svg`} />
    <title>{title}</title>
    <script is:inline>
      (() => {
        try {
          const saved = localStorage.getItem('deeporbit-theme');
          const theme = saved || (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          document.documentElement.dataset.theme = theme;
        } catch {}
      })();
    </script>
  </head>
  <body>
    <header class="header">
      <div class="container header-inner">
        <a class="brand" href={home} aria-label="DeepOrbit home">
          <svg viewBox="0 0 120 108" width="34" role="img" aria-label="DeepOrbit bird">
            <path d="M12 60C22 53 34 51 44 53C50 41 58 33 70 33C66 41 66 49 70 55C84 41 104 39 118 47C104 51 92 59 86 69C100 69 108 73 112 83C98 79 82 77 68 77C60 77 50 73 44 65C32 69 20 67 12 60Z" fill="none" stroke="currentColor" stroke-width="5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <span>DeepOrbit</span>
        </a>
        <nav aria-label="Primary navigation">
          <a href={`${home}#capabilities`}>{zh ? '能力' : 'Capabilities'}</a>
          <a href={`${home}#quickstart`}>{zh ? '快速开始' : 'Quickstart'}</a>
          <a href={`${home}docs/`}>{zh ? '文档' : 'Docs'}</a>
          <a href="https://github.com/dull-bird/DeepOrbit">GitHub</a>
          <a class="lang" href={`${base}${alternate}`}>{zh ? 'EN' : '中'}</a>
          <button id="theme" type="button" aria-label="Toggle color theme">◐</button>
        </nav>
      </div>
    </header>
    <main><slot /></main>
    <footer>
      <div class="container footer-inner">
        <div class="footer-brand">
          <span class="footer-name">DeepOrbit · dull-bird</span>
          <span class="footer-tagline">{zh ? '知识留在你的文件里，成长留在你身上。' : 'Knowledge stays in your files; the growth stays with you.'}</span>
        </div>
        <nav class="footer-links" aria-label="Footer navigation">
          {footerLinks.map((link) => <a href={link.href}>{link.label}</a>)}
        </nav>
      </div>
    </footer>
    <script is:inline>
      document.querySelector('#theme')?.addEventListener('click', () => {
        const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
        document.documentElement.dataset.theme = next;
        try { localStorage.setItem('deeporbit-theme', next); } catch {}
      });
    </script>
  </body>
</html>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 10;
    border-bottom: 1px solid var(--line);
    background: color-mix(in srgb, var(--paper) 86%, transparent);
    backdrop-filter: blur(14px);
  }
  .header-inner { min-height: 68px; display: flex; align-items: center; justify-content: space-between; gap: 24px; }
  .brand { display: inline-flex; align-items: center; gap: 10px; font-weight: 700; letter-spacing: -0.02em; }
  .brand svg { color: var(--accent); }
  nav { display: flex; align-items: center; gap: 20px; font-size: 0.9rem; }
  nav a { color: var(--body); transition: color var(--dur) var(--ease); }
  nav a:hover { color: var(--ink); }
  nav button {
    width: 36px; height: 36px;
    border: 1px solid var(--line);
    border-radius: 50%;
    color: var(--ink);
    background: transparent;
    cursor: pointer;
    transition: border-color var(--dur) var(--ease), transform var(--dur) var(--ease);
  }
  nav button:hover { border-color: var(--muted); transform: rotate(15deg); }
  .lang { color: var(--muted); }

  footer { margin-top: var(--space-10); border-top: 1px solid var(--line); }
  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    min-height: 96px;
    padding-block: var(--space-5);
    font-size: 0.86rem;
  }
  .footer-brand { display: grid; gap: 4px; }
  .footer-name { font-weight: 600; color: var(--ink); }
  .footer-tagline { color: var(--muted); }
  .footer-links { display: flex; flex-wrap: wrap; gap: 18px; font-size: 0.86rem; }

  @media (max-width: 720px) {
    nav a:not(.lang) { display: none; }
    .footer-inner { flex-direction: column; align-items: flex-start; gap: 14px; }
  }
</style>
