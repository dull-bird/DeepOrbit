  .lane-dot[data-lane="1"] { background: color-mix(in srgb, var(--accent) 72%, var(--sage)); }
  .lane-dot[data-lane="2"] { background: color-mix(in srgb, var(--accent) 45%, var(--sage)); }
  .lane-dot[data-lane="3"] { background: color-mix(in srgb, var(--accent) 20%, var(--sage)); }
