</style>

<script>
  const status = document.querySelector<HTMLParagraphElement>('.copy-status');
  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((button) => {
    button.addEventListener('click', async () => {
      const zh = document.documentElement.lang === 'zh';
      try {
        await navigator.clipboard.writeText(button.dataset.copy || '');
      } catch {
        if (status) status.textContent = zh
          ? '浏览器未允许剪贴板访问，请直接选择并复制命令。'
          : 'Clipboard access is unavailable. Select and copy the command directly.';
        return;
      }
      const label = button.querySelector<HTMLSpanElement>('.copy-label');
      const original = label?.textContent || '';
      if (label) label.textContent = zh ? '已复制' : 'Copied';
      if (status) status.textContent = zh ? '已复制到剪贴板。' : 'Copied to the clipboard.';
      window.setTimeout(() => { if (label) label.textContent = original; }, 1600);
    });
  });
</script>
