---
interface Props { lang: 'zh' | 'en' }
const { lang } = Astro.props;
const zh = lang === 'zh';
const base = import.meta.env.BASE_URL;
const home = zh ? base : `${base}en/`;

const capabilities = zh ? [
  ['01', '把碎片变成可连接的知识', '收集网页、PDF、想法和临时笔记；将它们整理为带 Properties、双链与来源的研究、Wiki 或写作。', 'do.research · do.note-summary · do.write'],
  ['02', '在自己的笔记里可靠检索', '默认使用本地 SQLite FTS；需要概念检索时可加 Chroma。每次查询只重建变化内容，也会删除失效条目。', 'do.rag · do.search · deeporbit index'],
  ['03', '把计划和项目推进下去', '从 Inbox 想法生成可审阅的计划与 C.A.P. 项目笔记；进度可以由任何 Agent 的 Goal/Tracker 增强，但不被它锁定。', 'do.kickoff · 90_Plans · 20_Projects'],
  ['04', '管理今天和未来的行动', '任务是标准 Markdown checkbox，能写入 Inbox、Daily Note 或项目；Agenda 汇总逾期与即将到期，ICS 导出连接日历。', 'do.todo · do.agenda · do.calendar'],
  ['05', '让 Obsidian 本身也更有用', '提供 Properties 模板、Projects/Research/Task Bases、Graph 指引和 Daily Note；Tasks、Dataview、Calendar 都只是可选增强。', 'Bases · Graph · Backlinks · Daily Notes'],
  ['06', '换电脑、换模型也不断档', 'Git 或 Obsidian Sync 同步 Markdown；每台电脑自行重建本地索引。Kimi、OpenClaw、Gemini 和 Codex 读取同一套 Skills。', 'Markdown source of truth · local cache']
] : [
  ['01', 'Turn fragments into connected knowledge', 'Capture links, PDFs, ideas, and rough notes; shape them into research, Wiki notes, or writing with Properties, links, and provenance.', 'do.research · do.note-summary · do.write'],
  ['02', 'Retrieve your own notes reliably', 'SQLite FTS is the default. Add Chroma for conceptual retrieval. Each query only reconciles changed files and removes deleted ones.', 'do.rag · do.search · deeporbit index'],
  ['03', 'Move plans and projects forward', 'Turn an Inbox idea into a reviewable plan and a C.A.P. project note. A runtime Goal or Tracker can help, but never owns the progress.', 'do.kickoff · 90_Plans · 20_Projects'],
  ['04', 'Manage today and the next action', 'Tasks are standard Markdown checkboxes in Inbox, Daily Notes, or projects. Agenda groups what is overdue; ICS export connects dated work to a calendar.', 'do.todo · do.agenda · do.calendar'],
  ['05', 'Make Obsidian useful on its own', 'Get Properties templates, Projects/Research/Task Bases, graph guidance, and Daily Notes. Tasks, Dataview, and Calendar remain optional views.', 'Bases · Graph · Backlinks · Daily Notes'],
  ['06', 'Change computers or models without losing flow', 'Git or Obsidian Sync carries Markdown; every computer rebuilds its local retrieval cache. Kimi, OpenClaw, Gemini, and Codex read the same Skills.', 'Markdown source of truth · local cache']
];

const runtimes = ['Kimi Code', 'OpenClaw', 'Gemini / Antigravity', 'Codex'];
const installOptions = zh ? [
  {
    name: '通用安装',
    context: '克隆仓库并安装本地 Core；适用于任何 Agent。',
    prompt: '请帮我安装 DeepOrbit：克隆 https://github.com/dull-bird/DeepOrbit.git，进入目录后执行 python3 -m pip install -e .。然后为我的 Obsidian vault 运行 deeporbit --vault <VAULT_PATH> init 和 doctor，并报告可用能力。',
    command: 'git clone https://github.com/dull-bird/DeepOrbit.git\ncd DeepOrbit\npython3 -m pip install -e .'
  },
  {
    name: 'Gemini / Antigravity',
    context: '链接本地 Extension，启用命令、MCP 与 hooks。',
    prompt: '请在本机安装并链接 DeepOrbit 的 Gemini Extension。若仓库未克隆，先克隆 https://github.com/dull-bird/DeepOrbit.git；然后执行 gemini extensions link <DEEPORBIT_PATH>，验证 extension，并说明如何为我的 vault 运行 deeporbit init。',
    command: 'gemini extensions link /path/to/DeepOrbit'
  },
  {
    name: 'Kimi Code',
    context: '直接加载标准 Agent Skills，不依赖插件市场。',
    prompt: '请为 Kimi Code 启用 DeepOrbit。克隆 https://github.com/dull-bird/DeepOrbit.git（如尚未存在），安装 Python Core，并以 kimi --skills-dir <DEEPORBIT_PATH>/skills 启动。请确认 do.todo、do.rag 和 do.calendar 可以被发现。',
    command: 'kimi --skills-dir /path/to/DeepOrbit/skills'
  },
  {
    name: 'OpenClaw',
    context: '把 portable Skills 放入当前工作区的 .agents/skills。',
    prompt: '请为当前 OpenClaw 工作区安装 DeepOrbit。克隆 https://github.com/dull-bird/DeepOrbit.git（如尚未存在），将其中每个 skills/do.* 文件夹复制或软链接到当前工作区 .agents/skills/，安装 Python Core，并运行 openclaw skills check 验证。',
    command: 'mkdir -p .agents/skills\ncp -R /path/to/DeepOrbit/skills/do.* .agents/skills/'
  },
  {
    name: 'Codex',
    context: '安装 portable Skills；插件与 MCP 作为可选增强。',
    prompt: '请为 Codex 安装 DeepOrbit。使用 npx skills add dull-bird/DeepOrbit 或克隆 https://github.com/dull-bird/DeepOrbit.git 后加载 skills/。安装 Python Core，初始化我的 Obsidian vault，并在可用时启用 .codex-plugin 与 mcp/deeporbit_rag/server.py。请验证 todo、rag、agenda 和 calendar 命令。',
    command: 'npx skills add dull-bird/DeepOrbit'
  }
] : [
  {
    name: 'Universal',
    context: 'Clone the repository and install the local Core for any agent.',
    prompt: 'Install DeepOrbit for me: clone https://github.com/dull-bird/DeepOrbit.git, enter the directory, and run python3 -m pip install -e .. Then run deeporbit --vault <VAULT_PATH> init and doctor for my Obsidian vault, and report available capabilities.',
    command: 'git clone https://github.com/dull-bird/DeepOrbit.git\ncd DeepOrbit\npython3 -m pip install -e .'
  },
  {
    name: 'Gemini / Antigravity',
    context: 'Link the local Extension to enable commands, MCP, and hooks.',
    prompt: 'Install and link the DeepOrbit Gemini Extension locally. Clone https://github.com/dull-bird/DeepOrbit.git if needed, run gemini extensions link <DEEPORBIT_PATH>, validate the extension, and explain how to run deeporbit init for my vault.',
    command: 'gemini extensions link /path/to/DeepOrbit'
  },
  {
    name: 'Kimi Code',
    context: 'Load standard Agent Skills directly, without a plugin marketplace.',
    prompt: 'Enable DeepOrbit for Kimi Code. Clone https://github.com/dull-bird/DeepOrbit.git if needed, install the Python Core, and start Kimi with kimi --skills-dir <DEEPORBIT_PATH>/skills. Confirm that do.todo, do.rag, and do.calendar are discoverable.',
    command: 'kimi --skills-dir /path/to/DeepOrbit/skills'
  },
  {
    name: 'OpenClaw',
    context: 'Place portable Skills in the current workspace .agents/skills directory.',
    prompt: 'Install DeepOrbit for my current OpenClaw workspace. Clone https://github.com/dull-bird/DeepOrbit.git if needed, copy or symlink each skills/do.* folder into the current workspace .agents/skills/, install the Python Core, and run openclaw skills check to verify it.',
    command: 'mkdir -p .agents/skills\ncp -R /path/to/DeepOrbit/skills/do.* .agents/skills/'
  },
  {
    name: 'Codex',
    context: 'Install portable Skills; plugin and MCP are optional enhancements.',
    prompt: 'Install DeepOrbit for Codex. Use npx skills add dull-bird/DeepOrbit, or clone https://github.com/dull-bird/DeepOrbit.git and load skills/. Install the Python Core, initialize my Obsidian vault, and enable .codex-plugin and mcp/deeporbit_rag/server.py if available. Verify todo, rag, agenda, and calendar.',
    command: 'npx skills add dull-bird/DeepOrbit'
  }
];
---
<section class="hero container">
  <div class="hero-title">
    <div class="eyebrow">Local first · Agent native · Obsidian</div>
    <h1>{zh ? <>不是又一个<br /><span>AI 笔记应用。</span></> : <>Not another<br /><span>AI notes app.</span></>}</h1>
  </div>
  <div class="hero-copy">
    <p class="reading-copy">{zh ? 'DeepOrbit 把你的 Obsidian vault 变成一个可研究、可检索、可行动的个人系统：知识留在 Markdown，任何 Agent 都能继续你的工作。' : 'DeepOrbit turns an Obsidian vault into a personal system for research, retrieval, and action. Knowledge stays in Markdown; any agent can carry the work forward.'}</p>
    <div class="actions">
      <a class="button primary" href="#capabilities">{zh ? '看它能做什么' : 'See what it does'}</a>
      <a class="button" href={`${home}docs/`}>{zh ? '三分钟上手' : 'Start in three minutes'}</a>
    </div>
  </div>
  <div class="orbit" aria-hidden="true"><i></i><b></b><span></span></div>
</section>

<section class="proof container" aria-label={zh ? 'DeepOrbit 的工作方式' : 'How DeepOrbit works'}>
  <div><span class="proof-number">Markdown</span><p>{zh ? '人类可读、可被 Git 和 Obsidian Sync 同步的权威来源。' : 'The readable source of truth for Git and Obsidian Sync.'}</p></div>
  <div><span class="proof-number">26 skills</span><p>{zh ? '研究、整理、检索、写作、项目和日常行动的一套可组合工作流。' : 'Composable workflows for research, organization, retrieval, writing, projects, and daily action.'}</p></div>
  <div><span class="proof-number">4 runtimes</span><p>{zh ? '同一套方法可在不同模型与终端 Agent 之间迁移。' : 'One system that moves across terminal agents and models.'}</p></div>
</section>

<section id="capabilities" class="container section">
  <div class="section-head">
    <div class="eyebrow">Capabilities</div>
    <div>
      <h2>{zh ? '从一条念头，到可复用的知识与下一步行动。' : 'From one thought to reusable knowledge and the next action.'}</h2>
      <p class="section-intro">{zh ? 'DeepOrbit 不是替你生成更多文本；它给每一类信息一个能被人和 Agent 长期维护的位置。' : 'DeepOrbit does not simply generate more text. It gives each kind of information a place people and agents can maintain over time.'}</p>
    </div>
  </div>
  <div class="capability-list">
    {capabilities.map(([number, title, text, tools]) => (
      <article class="capability">
        <span class="capability-number">{number}</span>
        <div><h3>{title}</h3><p>{text}</p></div>
        <code>{tools}</code>
      </article>
    ))}
  </div>
</section>

<section class="well">
  <div class="container section system-grid">
    <div class="system-copy">
      <div class="eyebrow">A concrete day</div>
      <h2>{zh ? '你说一句话，系统留下可继续的轨迹。' : 'One sentence leaves a trail you can continue.'}</h2>
      <p class="reading-copy">{zh ? '它不要求你迁移到专有数据库，也不要求永远使用同一个模型。你能看见、编辑并带走每一步。' : 'It does not require a proprietary database or one permanent model. You can inspect, edit, and carry every step with you.'}</p>
    </div>
    <ol class="day-flow">
      <li><span>01</span><div><strong>{zh ? '捕捉' : 'Capture'}</strong><p>{zh ? '“把这篇论文加到今天，并研究它和我之前的 RAG 笔记有什么关系。”' : '“Add this paper to today and compare it with my earlier RAG notes.”'}</p></div></li>
      <li><span>02</span><div><strong>{zh ? '检索与研究' : 'Retrieve & research'}</strong><p>{zh ? 'Agent 先读取相关 vault 内容，再输出有来源的研究 checkpoint。' : 'The agent retrieves related vault context, then writes a sourced research checkpoint.'}</p></div></li>
      <li><span>03</span><div><strong>{zh ? '沉淀' : 'Make it durable'}</strong><p>{zh ? '结论进入 Research 或 Wiki，任务进入 Daily Note 或项目，而不是消失在聊天记录里。' : 'Findings enter Research or Wiki; tasks enter a Daily Note or project instead of disappearing into chat.'}</p></div></li>
      <li><span>04</span><div><strong>{zh ? '明天继续' : 'Continue tomorrow'}</strong><p>{zh ? 'Agenda、Base 和日历把未完成事项重新带到眼前；换电脑后检索自动恢复。' : 'Agenda, Bases, and calendar bring unfinished work back; retrieval rebuilds on the next computer.'}</p></div></li>
    </ol>
  </div>
</section>

<section class="container section command-section">
  <div class="section-head">
    <div class="eyebrow">No black box</div>
    <div><h2>{zh ? '你可以直接运行，也可以自然语言交给 Agent。' : 'Run it directly, or ask an agent naturally.'}</h2><p class="section-intro">{zh ? 'Python Core 做需要精确性的事；Skills 告诉不同 Agent 何时采用哪一种工作流。' : 'The Python Core handles operations that need exactness; Skills tell different agents when to use which workflow.'}</p></div>
  </div>
  <div class="command-grid">
    <div class="terminal" aria-label="DeepOrbit command example">
      <div class="terminal-head"><span></span><span></span><span></span><b>your-vault</b></div>
      <pre><code>$ deeporbit --vault ~/Vault init
$ deeporbit --vault ~/Vault todo add "Review paper" --today
$ deeporbit --vault ~/Vault rag "retrieval strategy"
$ deeporbit --vault ~/Vault agenda
$ deeporbit --vault ~/Vault calendar export</code></pre>
    </div>
    <div class="command-notes">
      <p><b>{zh ? '没有 Obsidian CLI？' : 'No Obsidian CLI?'}</b> {zh ? '打开笔记时依次回退到 obsidian URI 和普通路径。' : 'Opening a note falls back to an obsidian URI, then a regular path.'}</p>
      <p><b>{zh ? '没有 Chroma 或 MCP？' : 'No Chroma or MCP?'}</b> {zh ? 'SQLite FTS 与 CLI 继续可用。' : 'SQLite FTS and the CLI continue to work.'}</p>
      <p><b>{zh ? '没有 Tasks/Dataview？' : 'No Tasks/Dataview?'}</b> {zh ? '任务仍然是可读、可同步的 Markdown。' : 'Tasks remain readable, syncable Markdown.'}</p>
      <a class="text-link" href={`${home}docs/`}>{zh ? '查看安装、同步和任务文档' : 'Read installation, sync, and task docs'} <span aria-hidden="true">→</span></a>
    </div>
  </div>
</section>

<section id="install" class="well install-section">
  <div class="container section">
    <div class="section-head">
      <div class="eyebrow">Install prompts</div>
      <div><h2>{zh ? '选一个运行时，复制一条能执行的安装提示词。' : 'Choose a runtime. Copy one prompt an agent can execute.'}</h2><p class="section-intro">{zh ? '这些按钮复制的是完整安装请求：它会要求 Agent 克隆、安装、验证，并且不把缓存或密钥写入你的 vault。命令行用户也可以直接复制右侧命令。' : 'Each button copies a complete request: clone, install, validate, and keep caches and secrets out of the vault. Terminal users can copy the direct command at right.'}</p></div>
    </div>
    <div class="install-list">
      {installOptions.map((option) => (
        <article class="install-row">
          <div><h3>{option.name}</h3><p>{option.context}</p></div>
          <pre><code>{option.command}</code></pre>
          <div class="install-actions">
            <button class="copy-button" type="button" data-copy={option.prompt} data-label={zh ? '复制安装提示词' : 'Copy install prompt'}>{zh ? '复制安装提示词' : 'Copy install prompt'}</button>
            <button class="copy-command" type="button" data-copy={option.command} data-label={zh ? '复制命令' : 'Copy command'}>{zh ? '复制命令' : 'Copy command'}</button>
          </div>
        </article>
      ))}
    </div>
    <p id="copy-status" class="copy-status" aria-live="polite"></p>
  </div>
</section>

<section class="container section runtime-section">
  <div class="section-head"><div class="eyebrow">One portable contract</div><div><h2>{zh ? '选择你的 Agent，而不是被 Agent 选择。' : 'Choose your agent. Do not be chosen by one.'}</h2><p class="section-intro">{zh ? '运行时的 hooks、MCP 和 Goal 只提升体验；计划、任务和知识都留在任何工具可读的文件中。' : 'Runtime hooks, MCP, and Goals improve the experience; plans, tasks, and knowledge stay in files every tool can read.'}</p></div></div>
  <div class="runtime-list">
    {runtimes.map((runtime, index) => <div class="runtime-row"><span>0{index + 1}</span><h3>{runtime}</h3><p>{zh ? '读取相同的 Agent Skills、Markdown checkpoints 与设备本地检索缓存。' : 'Reads the same Agent Skills, Markdown checkpoints, and device-local retrieval cache.'}</p></div>)}
  </div>
</section>

<section class="cta container">
  <div><div class="eyebrow">Start local</div><h2>{zh ? '先创建一个你的 vault。' : 'Start with a vault you own.'}</h2></div>
  <div><p>{zh ? '三分钟安装、初始化并创建第一条可检索任务。之后，它会随着你的研究与项目一起生长。' : 'Install, initialize, and create a first retrievable task in three minutes. From there, it grows with your work.'}</p><a class="button primary" href={`${home}docs/`}>{zh ? '开始使用 DeepOrbit' : 'Start using DeepOrbit'}</a></div>
</section>

<style>
  .hero { position: relative; min-height: calc(100dvh - 72px); display: grid; grid-template-columns: 1.12fr .88fr; align-items: center; gap: 64px; padding-block: 80px; overflow: hidden; }
  .hero-title { position: relative; z-index: 1; }
  .hero h1 { margin-top: 18px; max-width: 760px; }
  .hero h1 span { color: var(--accent); }
  .hero-copy { position: relative; z-index: 1; align-self: end; padding-bottom: 12vh; max-width: 560px; }
  .actions { display: flex; gap: 12px; margin-top: 30px; flex-wrap: wrap; }
  .orbit { position: absolute; width: min(52vw, 650px); aspect-ratio: 1; border: 1px solid var(--line); border-radius: 50%; right: -22%; top: -18%; opacity: .8; animation: drift 12s ease-in-out infinite alternate; }
  .orbit::after { content: ''; position: absolute; inset: 18%; border: 1px solid var(--line); border-radius: 50%; }
  .orbit i, .orbit b, .orbit span { position: absolute; display: block; border-radius: 50%; background: var(--accent); }
  .orbit i { width: 14px; height: 14px; left: 13%; top: 27%; }
  .orbit b { width: 8px; height: 8px; right: 14%; bottom: 32%; }
  .orbit span { width: 5px; height: 5px; left: 47%; bottom: 18%; }
  .proof { display: grid; grid-template-columns: repeat(3, 1fr); border-block: 1px solid var(--line); }
  .proof > div { padding: 28px 28px 30px 0; border-right: 1px solid var(--line); }
  .proof > div + div { padding-left: 28px; }
  .proof > div:last-child { border-right: 0; }
  .proof-number { display: block; font-size: clamp(1.25rem, 2vw, 1.7rem); font-weight: 700; letter-spacing: -.03em; }
  .proof p, .capability p, .runtime-row p, .command-notes p, .day-flow p { margin: 8px 0 0; color: var(--body); }
  .section { padding-block: 120px; }
  .section-head { display: grid; grid-template-columns: .62fr 1.38fr; gap: 32px; align-items: start; margin-bottom: 64px; }
  .section-intro { max-width: 660px; margin: 18px 0 0; color: var(--body); font-family: var(--reading); font-size: 1.08rem; line-height: 1.85; }
  .capability-list { border-top: 1px solid var(--line); }
  .capability { display: grid; grid-template-columns: 80px minmax(0, 1fr) minmax(160px, .55fr); gap: 32px; align-items: start; padding: 34px 0; border-bottom: 1px solid var(--line); }
  .capability h3 { font-size: clamp(1.25rem, 2.4vw, 1.75rem); }
  .capability-number { color: var(--accent-ink); font-size: .85rem; font-weight: 700; padding-top: 5px; }
  .capability code { align-self: center; color: var(--muted); font-size: .8rem; line-height: 1.55; white-space: normal; }
  .well { background: var(--surface); border-block: 1px solid var(--line); }
  .system-grid { display: grid; grid-template-columns: .85fr 1.15fr; gap: 100px; align-items: start; }
  .system-copy h2 { margin: 18px 0 26px; }
  .day-flow { list-style: none; padding: 0; margin: 0; border-top: 1px solid var(--line); }
  .day-flow li { display: grid; grid-template-columns: 54px 1fr; gap: 18px; padding: 25px 0; border-bottom: 1px solid var(--line); }
  .day-flow span { color: var(--accent-ink); font-size: .8rem; padding-top: 3px; }
  .day-flow strong { font-size: 1.15rem; }
  .command-grid { display: grid; grid-template-columns: 1.2fr .8fr; gap: 48px; align-items: stretch; }
  .terminal { overflow: hidden; background: #1c1b19; border: 1px solid #34322e; border-radius: 14px; color: #efede6; }
  .terminal-head { display: flex; align-items: center; gap: 7px; min-height: 42px; padding: 0 15px; border-bottom: 1px solid #34322e; color: #aaa59b; font-size: .78rem; }
  .terminal-head span { width: 8px; height: 8px; border-radius: 50%; background: #7d786f; }
  .terminal-head b { margin-left: 7px; font-weight: 500; }
  .terminal pre { margin: 0; padding: 24px; border: 0; border-radius: 0; background: transparent; color: inherit; white-space: pre-wrap; }
  .terminal code { padding: 0; background: transparent; color: inherit; line-height: 1.9; }
  .command-notes { display: grid; align-content: center; gap: 20px; }
  .command-notes p { margin: 0; line-height: 1.75; }
  .command-notes b { color: var(--ink); }
  .text-link { margin-top: 6px; color: var(--accent-ink); font-weight: 700; }
  .text-link span { display: inline-block; transition: transform .18s ease; }
  .text-link:hover span { transform: translateX(4px); }
  .runtime-list { border-top: 1px solid var(--line); }
  .runtime-row { display: grid; grid-template-columns: 80px minmax(160px, .55fr) 1.45fr; gap: 32px; padding: 26px 0; border-bottom: 1px solid var(--line); align-items: baseline; }
  .runtime-row > span { color: var(--accent-ink); font-size: .82rem; }
  .runtime-row p { margin: 0; }
  .install-section { border-block: 1px solid var(--line); }
  .install-list { border-top: 1px solid var(--line); }
  .install-row { display: grid; grid-template-columns: minmax(180px, .7fr) minmax(250px, 1fr) auto; gap: 28px; align-items: center; padding: 25px 0; border-bottom: 1px solid var(--line); }
  .install-row h3 { font-size: 1.12rem; }
  .install-row p { margin: 7px 0 0; color: var(--body); font-size: .92rem; }
  .install-row pre { margin: 0; padding: 14px; border-radius: 9px; font-size: .78rem; line-height: 1.6; }
  .install-row pre code { padding: 0; background: transparent; white-space: pre-wrap; }
  .install-actions { display: grid; gap: 8px; justify-items: stretch; }
  .copy-button, .copy-command { min-height: 38px; padding: 8px 12px; border: 1px solid var(--line); border-radius: 999px; background: transparent; color: var(--ink); cursor: pointer; font: inherit; font-size: .8rem; font-weight: 700; white-space: nowrap; transition: transform .18s ease, background .18s ease; }
  .copy-button { color: var(--paper); background: var(--ink); border-color: var(--ink); }
  .copy-button:hover, .copy-command:hover { transform: translateY(-1px); }
  .copy-button:active, .copy-command:active { transform: scale(.98); }
  .copy-status { min-height: 1.5em; margin: 18px 0 0; color: var(--accent-ink); font-size: .88rem; }
  .cta { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; margin-block: 40px 120px; padding: 56px; background: var(--ink); color: var(--paper); }
  .cta .eyebrow { color: var(--accent); }
  .cta h2 { margin-top: 16px; }
  .cta p { color: color-mix(in srgb, var(--paper) 76%, transparent); max-width: 480px; margin: 0 0 28px; font-family: var(--reading); line-height: 1.8; }
  .cta .primary { color: var(--ink); background: var(--paper); border-color: var(--paper); }
  @keyframes drift { to { transform: translate(-24px, 18px) rotate(8deg); } }
  @media (max-width: 760px) {
    .hero, .section-head, .system-grid, .command-grid, .cta { grid-template-columns: 1fr; }
    .hero { min-height: auto; gap: 30px; padding-block: 82px; }
    .hero-copy { padding: 0; }
    .orbit { opacity: .35; }
    .proof { grid-template-columns: 1fr; }
    .proof > div, .proof > div + div { padding: 22px 0; border-right: 0; border-bottom: 1px solid var(--line); }
    .proof > div:last-child { border-bottom: 0; }
    .section { padding-block: 80px; }
    .capability, .runtime-row { grid-template-columns: 54px 1fr; gap: 14px; }
    .capability code { grid-column: 2; }
    .runtime-row p { grid-column: 2; }
    .install-row { grid-template-columns: 1fr; gap: 14px; }
    .install-actions { grid-template-columns: 1fr 1fr; }
    .system-grid { gap: 52px; }
    .cta { margin-inline: 0; padding: 40px 28px; gap: 32px; }
  }
</style>

<script>
  const status = document.querySelector<HTMLParagraphElement>('#copy-status');
  const copy = async (value: string) => {
    if (!navigator.clipboard) throw new Error('Clipboard API unavailable');
    await navigator.clipboard.writeText(value);
  };

  document.querySelectorAll<HTMLButtonElement>('[data-copy]').forEach((button) => {
    button.addEventListener('click', async () => {
      try {
        await copy(button.dataset.copy || '');
      } catch {
        if (status) status.textContent = button.dataset.label?.includes('复制')
          ? '浏览器未允许剪贴板访问，请直接选择并复制右侧命令。'
          : 'Clipboard access is unavailable. Select and copy the command directly.';
        return;
      }
      const label = button.dataset.label || 'Copied';
      const original = button.textContent;
      button.textContent = label.includes('复制') ? '已复制' : 'Copied';
      if (status) status.textContent = label.includes('复制') ? '已复制到剪贴板。' : 'Copied to the clipboard.';
      window.setTimeout(() => { button.textContent = original; }, 1600);
    });
  });
</script>
