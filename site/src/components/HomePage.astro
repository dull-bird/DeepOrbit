  .loop-num {
    display: inline-flex;
    width: 34px;
    height: 34px;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--line-strong);
    border-radius: 50%;
    color: var(--sage-ink);
    font-family: var(--mono);
    font-size: 0.85rem;
    background: var(--sage-soft);
  }
  .loop-steps strong { font-size: 1.05rem; }
  .loop-steps p { margin: 6px 0 0; font-size: 0.92rem; }
  .loop-back { color: var(--sage-ink); font-size: 1.3rem; line-height: 1; padding-top: 6px; }
  .loop-asset { aspect-ratio: 1 / 1.1; }

  /* ---------- runtimes ---------- */
  .runtime-section { padding-block: var(--space-8); }
  .runtime-section .section-head { margin-bottom: var(--space-6); }
  .runtime-badges {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin: 0;
    padding: 0;
  }
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 10px 18px;
    border: 1px solid var(--line);
