---
interface Props { lang: 'zh' | 'en' }
const { lang } = Astro.props;
const zh = lang === 'zh';
const base = import.meta.env.BASE_URL;
const home = zh ? base : `${base}en/`;

const stats = zh ? [
  ['31', 'do.* 工作流技能'],
  ['11', '语义化目录'],
  ['5', 'Agent 运行时'],
  ['0', '云端账号'],
] : [
  ['31', 'do.* workflow skills'],
  ['11', 'semantic directories'],
  ['5', 'agent runtimes'],
  ['0', 'cloud accounts'],
];

const problems = zh ? [
  ['任务散落', '待办躺在聊天记录、便签和五个 App 里。没有任何一个地方，称得上“事实”。'],
  ['项目烂尾', '开始总是雄心勃勃；两周之后，没人记得进行到了哪一步，也没人敢翻旧账。'],
  ['知识不沉淀', '做过的研究、读过的论文、想通的道理，随着对话窗口关闭一起消失。'],
] : [
  ['Scattered tasks', 'Todos live in chat logs, sticky notes, and five different apps. Nowhere counts as the truth.'],
  ['Stalled projects', 'Every project starts with ambition. Two weeks later, nobody remembers where it stopped.'],
  ['Knowledge that evaporates', 'Research done, papers read, lessons learned — all gone the moment the chat window closes.'],
];

const icons = {
  vault: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4 8l8-4 8 4v8l-8 4-8-4V8z"/><path d="M4 8l8 4 8-4"/><path d="M12 12v8"/></svg>',
  skills: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l9 5-9 5-9-5 9-5z"/><path d="M3 13l9 5 9-5"/><path d="M3 17.5l9 5 9-5" opacity=".45"/></svg>',
  lifecycle: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12a8 8 0 0 1 13.6-5.7"/><path d="M20 12a8 8 0 0 1-13.6 5.7"/><path d="M17.5 3v3.3h-3.3"/><path d="M6.5 21v-3.3h3.3"/></svg>',
  growth: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20V10"/><path d="M12 10c0-4 3-7 8-7 0 4-3 7-8 7z"/><path d="M12 14c0-3-2.5-5.5-6.5-5.5 0 3.5 2.5 5.5 6.5 5.5z"/></svg>',
  privacy: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 5-3 8.5-7 10-4-1.5-7-5-7-10V6l7-3z"/><path d="M9 11.5l2 2 4-4.5"/></svg>',
} as const;

type IconKey = keyof typeof icons;

const capabilities: Array<[IconKey, string, string, string]> = zh ? [
  ['vault', '便携 Markdown 知识库', 'Vault 即事实：纯文本、可 Git 同步、无厂商锁定。换电脑、换工具、换模型，知识原样带走。', '00_Inbox → 99_System'],
  ['skills', '31 个 do.* 工作流技能', 'daily、todo、agenda、research、recap、dream、mentor……同一套技能，在五个运行时里行为一致。', 'do.todo · do.research · do.dream'],
  ['lifecycle', '工作生命周期', '每份工作都有状态：active | paused | done | archived。deeporbit serve 打开本地仪表盘，进展一目了然。', 'deeporbit status · serve'],
  ['growth', '与 teach-me 联动', '沉淀的知识导出为学习者画像：你掌握什么、卡在哪里，系统越用越懂你。', 'do.teach-me · learner profile'],
  ['privacy', '本地优先，隐私自控', '只读区、隐私阀门、Cron 与 Recipe 自动化——全部运行在你自己的机器上，不需要任何账号。', 'readonly zones · cron · recipes'],
] : [
  ['vault', 'A portable Markdown vault', 'The vault is the source of truth: plain text, Git-syncable, zero vendor lock-in. Change computers, tools, or models — knowledge travels as-is.', '00_Inbox → 99_System'],
  ['skills', '31 do.* workflow skills', 'daily, todo, agenda, research, recap, dream, mentor… The same skills behave the same across five runtimes.', 'do.todo · do.research · do.dream'],
  ['lifecycle', 'A lifecycle for work', 'Every piece of work carries a status: active | paused | done | archived. deeporbit serve opens a local dashboard that keeps progress visible.', 'deeporbit status · serve'],
  ['growth', 'Linked with teach-me', 'Distilled knowledge exports into a learner profile — what you have mastered, where you are stuck. A system that knows you better over time.', 'do.teach-me · learner profile'],
  ['privacy', 'Local-first, privacy on your terms', 'Read-only zones, privacy valves, cron and recipe automation — everything runs on your own machine. No account required.', 'readonly zones · cron · recipes'],
];

const vaultLanes = zh ? [
  ['捕捉', '想法与任务的第一站', ['00_Inbox']],
  ['记录', '日常、写作与生活', ['10_Diary', '15_Writings', '70_Family']],
  ['推进', '项目与可审阅的计划', ['20_Projects', '90_Plans']],
  ['沉淀', '研究、概念与资料', ['30_Research', '40_Wiki', '50_Resources', '60_Notes']],
  ['系统', '模板、Bases 与归档', ['99_System']],
] : [
  ['Capture', 'First stop for ideas and tasks', ['00_Inbox']],
  ['Record', 'Diary, writing, and life', ['10_Diary', '15_Writings', '70_Family']],
  ['Act', 'Projects and reviewable plans', ['20_Projects', '90_Plans']],
  ['Distill', 'Research, concepts, resources', ['30_Research', '40_Wiki', '50_Resources', '60_Notes']],
  ['System', 'Templates, Bases, and archives', ['99_System']],
];

const dashboardPoints = zh ? [
  ['全库状态总览', '进行中、已暂停、已完成、待归档——一张图回答“我在做什么”。'],
  ['一键流转', '暂停、恢复、完成、归档，都由 CLI 安全执行，从不覆盖文件。'],
  ['建议与 ACP 面板', '基于 vault 状态给出下一步建议，也可以直接让 Agent 接手。'],
] : [
  ['Vault-wide overview', 'Active, paused, done, ready to archive — one picture answers “what am I doing”.'],
  ['One-click transitions', 'Pause, resume, complete, archive — every transition runs through the safe CLI and never overwrites a file.'],
  ['Suggestions & ACP panel', 'Next steps derived from vault state, with an agent panel ready to take over.'],
];

const loopSteps = zh ? [
  ['完成工作', '任务、项目与日常都在 vault 里留下真实轨迹。'],
  ['提炼学习', 'teach-me 把轨迹提炼成概念、掌握度与薄弱点。'],
  ['更新画像', '学习者画像随每次工作持续生长，始终留在本地。'],
  ['更懂你', 'Agent 按画像调整教学与协作——你再带着它出发。'],
] : [
  ['Do the work', 'Tasks, projects, and daily notes leave a real trail in the vault.'],
  ['Distill the learning', 'teach-me turns that trail into concepts, mastery, and weak spots.'],
  ['Grow the profile', 'Your learner profile compounds with every session, always local.'],
  ['Know you better', 'Agents teach and collaborate from the profile — and off you go again.'],
];

const runtimes = ['Claude Code', 'Codex', 'Gemini', 'OMP', 'OpenClaw'];

const quickstart = zh ? [
  ['安装技能', '把 portable Skills 装进你正在用的 Agent 运行时。', 'npx skills add dull-bird/DeepOrbit'],
  ['初始化 vault', '生成目录模型、模板、Bases 与技能索引；已有笔记原样保留。', 'deeporbit --vault ~/MyVault init'],
  ['打开仪表盘', '本地仪表盘即刻呈现工作状态：active、paused、done、archived。', 'deeporbit --vault ~/MyVault serve --open'],
] : [
  ['Add the skills', 'Install the portable Skills into the agent runtime you already use.', 'npx skills add dull-bird/DeepOrbit'],
  ['Initialize a vault', 'Materializes the directory model, templates, Bases, and skill index — existing notes are preserved.', 'deeporbit --vault ~/MyVault init'],
  ['Open the dashboard', 'A local dashboard shows the state of your work: active, paused, done, archived.', 'deeporbit --vault ~/MyVault serve --open'],
];
---

<!-- ============ Hero ============ -->
<section class="hero container">
  <div class="hero-copy">
    <div class="eyebrow">DeepOrbit 2.0 · {zh ? '本地优先的 Agent Skills 套件' : 'Local-first Agent Skills'}</div>
    <h1>{zh ? <>你的任务、项目和知识，<br />应该长成<span class="accent">同一个系统。</span></> : <>Your tasks, projects, and knowledge should grow into <span class="accent">one system.</span></>}</h1>
    <p class="hero-sub">{zh ? 'DeepOrbit 把 Obsidian vault 变成任务、项目与知识管理系统：31 个可移植的工作流技能，跨 Claude Code、Codex、Gemini、OMP 与 OpenClaw 复用——知识留在 Markdown，成长留给你。' : 'DeepOrbit turns an Obsidian vault into a system for tasks, projects, and knowledge: 31 portable workflow skills across Claude Code, Codex, Gemini, OMP, and OpenClaw. Knowledge stays in Markdown; the growth stays with you.'}</p>
    <div class="actions">
      <a class="button primary" href={`${home}docs/`}>{zh ? '开始使用' : 'Get started'} <span class="arrow" aria-hidden="true">→</span></a>
      <a class="button" href="https://github.com/dull-bird/DeepOrbit">GitHub</a>
    </div>
  </div>
  <div class="asset hero-asset" data-asset="hero" role="img" aria-label={zh ? '主视觉插图占位' : 'Hero illustration placeholder'}>
    <span>{zh ? '主视觉：hero' : 'Illustration: hero'}</span>
  </div>
</section>

<section class="stats container" aria-label={zh ? '关键数字' : 'Key numbers'}>
  {stats.map(([num, label]) => (
    <div class="stat"><span class="stat-num">{num}</span><span class="stat-label">{label}</span></div>
  ))}
</section>

<!-- ============ Problems ============ -->
<section class="container section problems-section">
  <div class="section-head">
    <div class="eyebrow">{zh ? '三个老问题' : 'Three old problems'}</div>
    <h2>{zh ? '你不是不努力，是系统不支持你。' : 'You are not unproductive. Your system does not support you.'}</h2>
  </div>
  <div class="problems-grid">
    {problems.map(([title, text], i) => (
      <article class="problem">
        <span class="problem-num">0{i + 1}</span>
        <h3>{title}</h3>
        <p>{text}</p>
      </article>
    ))}
  </div>
</section>

<!-- ============ Capabilities ============ -->
<section id="capabilities" class="well">
  <div class="container section">
    <div class="section-head">
      <div class="eyebrow">{zh ? '核心能力' : 'Core capabilities'}</div>
      <div>
        <h2>{zh ? '一个 vault，管好任务、项目与知识。' : 'One vault for tasks, projects, and knowledge.'}</h2>
        <p class="section-intro">{zh ? '不是替你生成更多文本，而是给每一类信息一个人和 Agent 都能长期维护的位置。' : 'Not more generated text — a durable place for every kind of information, maintained by you and your agents.'}</p>
      </div>
    </div>
    <div class="capability-grid">
      {capabilities.map(([icon, title, text, meta]) => (
        <article class="capability-card">
          <span class="card-icon" set:html={icons[icon]} />
          <h3>{title}</h3>
          <p>{text}</p>
          <code>{meta}</code>
        </article>
      ))}
      <article class="capability-card example-card">
        <span class="card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M8 12h8M12 8v8"/></svg>
        </span>
        <h3>{zh ? '先逛逛示例 Vault' : 'Tour the example vault'}</h3>
        <p>{zh ? '不想先装东西？克隆 deeporbit-example-vault，直接看一个活着的 DeepOrbit 知识库长什么样。' : 'Not ready to install? Clone deeporbit-example-vault and see what a living DeepOrbit vault looks like.'}</p>
        <a class="text-link" href="https://github.com/dull-bird/deeporbit-example-vault">dull-bird/deeporbit-example-vault <span aria-hidden="true">→</span></a>
      </article>
    </div>
  </div>
</section>

<!-- ============ Vault model ============ -->
<section class="container section">
  <div class="section-head">
    <div class="eyebrow">{zh ? '工作方式' : 'How it works'}</div>
    <div>
      <h2>{zh ? '从一条念头，到可复用的知识。' : 'From a passing thought to reusable knowledge.'}</h2>
      <p class="section-intro">{zh ? '十一个语义化目录，五条流向。每一条信息都有去处，每一份工作都有状态。' : 'Eleven semantic directories, five lanes. Every piece of information has a destination; every piece of work has a state.'}</p>
    </div>
  </div>
  <div class="vault-flow" role="list" aria-label={zh ? 'Vault 目录模型' : 'Vault directory model'}>
    {vaultLanes.map(([lane, desc, folders], i) => (
      <div class="lane" role="listitem">
        <div class="lane-head">
          <span class="lane-dot" data-lane={i}></span>
          <strong>{lane}</strong>
        </div>
        <div class="lane-folders">
          {(folders as string[]).map((folder) => <code class="folder">{folder}</code>)}
        </div>
        <p class="lane-desc">{desc}</p>
      </div>
    ))}
  </div>
</section>

<!-- ============ Dashboard ============ -->
<section class="well">
  <div class="container section dashboard-grid">
    <div class="dashboard-copy">
      <div class="eyebrow">{zh ? '本地仪表盘' : 'Local dashboard'}</div>
      <h2>{zh ? <><code class="inline-cmd">deeporbit serve</code>：你的工作，一眼看清。</> : <><code class="inline-cmd">deeporbit serve</code>: your work at a glance.</>}</h2>
      <ul class="dashboard-list">
        {dashboardPoints.map(([title, text]) => (
          <li><strong>{title}</strong><p>{text}</p></li>
        ))}
      </ul>
    </div>
    <div class="asset dashboard-asset" data-asset="dashboard" role="img" aria-label={zh ? '仪表盘插图占位' : 'Dashboard illustration placeholder'}>
      <span>{zh ? '插图：dashboard' : 'Illustration: dashboard'}</span>
    </div>
  </div>
</section>

<!-- ============ Growth loop ============ -->
<section class="container section">
  <div class="section-head">
    <div class="eyebrow sage">{zh ? '成长闭环' : 'The growth loop'}</div>
    <div>
      <h2>{zh ? '不止管理，更是沉淀与成长。' : 'More than management — a loop that compounds.'}</h2>
      <p class="section-intro">{zh ? 'DeepOrbit 管事，teach-me 管人。每一次完成任务，都让系统更懂你一点。' : 'DeepOrbit manages the work; teach-me understands the worker. Every finished task makes the system know you better.'}</p>
    </div>
  </div>
  <div class="loop-grid">
    <ol class="loop-steps">
      {loopSteps.map(([title, text], i) => (
        <li>
          <span class="loop-num">{i + 1}</span>
          <div><strong>{title}</strong><p>{text}</p></div>
          {i === loopSteps.length - 1 && <span class="loop-back" aria-hidden="true">↻</span>}
        </li>
      ))}
    </ol>
    <div class="asset loop-asset" data-asset="learner-profile" role="img" aria-label={zh ? '学习者画像插图占位' : 'Learner profile illustration placeholder'}>
      <span>{zh ? '插图：learner-profile' : 'Illustration: learner-profile'}</span>
    </div>
  </div>
</section>

<!-- ============ Runtimes ============ -->
<section class="well runtime-well">
  <div class="container section runtime-section">
    <div class="section-head">
      <div class="eyebrow">{zh ? '跨运行时' : 'Cross-runtime'}</div>
      <div>
        <h2>{zh ? '选择你的 Agent，而不是被 Agent 选择。' : 'Choose your agent. Do not be chosen by one.'}</h2>
        <p class="section-intro">{zh ? '同一套 skills/，同一份 Markdown。换一个运行时，只是换一扇窗。' : 'The same skills/ directory, the same Markdown. Switching runtimes is just switching windows.'}</p>
      </div>
    </div>
    <ul class="runtime-badges" aria-label={zh ? '支持的运行时' : 'Supported runtimes'}>
      {runtimes.map((runtime) => <li class="badge"><span class="badge-dot" aria-hidden="true"></span>{runtime}</li>)}
    </ul>
  </div>
</section>

<!-- ============ Quickstart ============ -->
<section id="quickstart" class="container section">
  <div class="section-head">
    <div class="eyebrow">{zh ? '快速开始' : 'Quickstart'}</div>
    <div>
      <h2>{zh ? '三分钟，跑起来。' : 'Running in three minutes.'}</h2>
      <p class="section-intro">{zh ? '三条命令：装技能、初始化、打开仪表盘。之后的一切，都可以交给自然语言。' : 'Three commands: add the skills, initialize, open the dashboard. Everything after that is natural language.'}</p>
    </div>
  </div>
  <ol class="quickstart-list">
    {quickstart.map(([title, text, command], i) => (
      <li class="quickstart-step">
        <div class="step-head"><span class="step-num">0{i + 1}</span><div><h3>{title}</h3><p>{text}</p></div></div>
        <div class="step-cmd">
          <pre><code>{command}</code></pre>
          <button class="copy-btn" type="button" data-copy={command} aria-label={zh ? '复制命令' : 'Copy command'}>
            <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="12" height="12" rx="2"/><path d="M5 15V5a2 2 0 0 1 2-2h10"/></svg>
            <span class="copy-label">{zh ? '复制' : 'Copy'}</span>
          </button>
        </div>
      </li>
    ))}
  </ol>
  <p class="copy-status" aria-live="polite"></p>
</section>

<!-- ============ CTA ============ -->
<section class="cta container">
  <div>
    <div class="eyebrow">{zh ? '现在开始' : 'Start now'}</div>
    <h2>{zh ? '从今天的 Inbox 开始。' : 'Start with today’s Inbox.'}</h2>
  </div>
  <div>
    <p>{zh ? '三分钟安装、初始化，并创建第一条可检索的任务。之后，它会随你的研究与项目一起生长。' : 'Install, initialize, and capture your first retrievable task in three minutes. From there, it grows with your research and projects.'}</p>
    <div class="actions">
      <a class="button primary" href={`${home}docs/`}>{zh ? '阅读文档' : 'Read the docs'} <span class="arrow" aria-hidden="true">→</span></a>
      <a class="button ghost" href="https://github.com/dull-bird/DeepOrbit">GitHub</a>
    </div>
  </div>
</section>

<style>
  /* ---------- hero ---------- */
  .hero {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    align-items: center;
    gap: clamp(40px, 6vw, 88px);
    padding-block: clamp(64px, 10vh, 120px) var(--space-8);
  }
  .hero h1 {
    margin-top: var(--space-4);
    font-size: clamp(2.3rem, 4.4vw, 3.5rem);
    line-height: 1.28;
    word-break: keep-all;
  }
  .hero h1 .accent { color: var(--accent); }
  .hero-sub {
    max-width: 560px;
    margin: var(--space-5) 0 0;
    font-size: 1.08rem;
    line-height: 1.85;
  }
  .actions { display: flex; gap: 12px; margin-top: var(--space-6); flex-wrap: wrap; }
  .hero-asset { aspect-ratio: 4 / 3.2; }

  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-block: 1px solid var(--line);
  }
  .stat { padding: var(--space-5) var(--space-5) var(--space-5) 0; border-right: 1px solid var(--line); }
  .stat + .stat { padding-left: var(--space-5); }
  .stat:last-child { border-right: 0; }
  .stat-num {
    display: block;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    font-variant-numeric: tabular-nums;
  }
  .stat-label { color: var(--muted); font-size: 0.86rem; }

  /* ---------- shared section scaffolding ---------- */
  .section { padding-block: var(--space-9); }
  .section-head {
    display: grid;
    grid-template-columns: 0.62fr 1.38fr;
    gap: 32px;
    align-items: start;
    margin-bottom: var(--space-7);
  }
  .section-head h2 { max-width: 720px; }
  .section-intro {
    max-width: 640px;
    margin: var(--space-4) 0 0;
    color: var(--body);
    font-family: var(--reading);
    font-size: 1.06rem;
    line-height: 1.85;
  }
  .well { background: var(--surface); border-block: 1px solid var(--line); }
  .text-link { color: var(--accent-ink); font-weight: 700; font-size: 0.92rem; }
  .text-link span { display: inline-block; transition: transform var(--dur) var(--ease); }
  .text-link:hover span { transform: translateX(4px); }

  /* ---------- problems ---------- */
  .problems-section { padding-bottom: var(--space-9); }
  .problems-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-5); }
  .problem {
    padding: var(--space-6) var(--space-5);
    border: 1px solid var(--line);
    border-radius: var(--radius-l);
    background: var(--paper);
    transition: border-color var(--dur) var(--ease), box-shadow var(--dur) var(--ease), transform var(--dur) var(--ease);
  }
  .problem:hover { border-color: var(--line-strong); box-shadow: var(--shadow-m); transform: translateY(-3px); }
  .problem-num { color: var(--accent-ink); font-family: var(--mono); font-size: 0.8rem; }
  .problem h3 { margin-top: var(--space-3); }
  .problem p { margin: var(--space-3) 0 0; }

  /* ---------- capabilities ---------- */
  .capability-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-5); }
  .capability-card {
    display: flex;
    flex-direction: column;
    padding: var(--space-6) var(--space-5);
    border: 1px solid var(--line);
    border-radius: var(--radius-l);
    background: var(--paper);
    transition: border-color var(--dur) var(--ease), box-shadow var(--dur) var(--ease), transform var(--dur) var(--ease);
  }
  .capability-card:hover { border-color: var(--line-strong); box-shadow: var(--shadow-m); transform: translateY(-3px); }
  .card-icon {
    display: inline-flex;
    width: 40px;
    height: 40px;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--line);
