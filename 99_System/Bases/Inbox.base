filters:
  and:
    - 'file.inFolder("00_Inbox")'
views:
  - type: table
    name: 待处理 Unprocessed
    filters:
      and:
        - 'status != "processed"'
    order:
      - file.name
      - file.ctime
    sort:
      - property: file.ctime
        direction: DESC
  - type: table
    name: 已处理 Processed
    filters:
      and:
        - 'status == "processed"'
    order:
      - file.name
      - updated
